#!/usr/bin/env zsh

TRACKPAD_ID="${TRACKPAD_ID:-64:C7:53:EE:D7:2F}"

is_connected() {
  blueutil --is-connected "$TRACKPAD_ID" 2>/dev/null | grep -q "1"
}

echo "🖱️  Trackpad: $TRACKPAD_ID"

case "${1:-switch}" in
  forget)
    echo "📡 Checking connection..."
    if is_connected; then
      echo "✅ Trackpad is connected."
    else
      echo "⚠️  Trackpad is not connected — unpairing anyway..."
    fi
    echo "🗑️  Forgetting trackpad..."
    blueutil --unpair "$TRACKPAD_ID"
    echo "✅ Done. You can now pair it with another computer."
    ;;

  add)
    echo "💡 Put your trackpad in pairing mode (hold power button until LED blinks)"
    read -r "?Press Enter when ready..."
    echo "🔗 Sending pair request..."
    blueutil --pair "$TRACKPAD_ID" --connect "$TRACKPAD_ID"
    echo ""
    echo "📡 Verifying connection..."
    if is_connected; then
      echo "✅ Trackpad connected!"
    else
      echo "⚠️  Trackpad not detected yet — it may take a moment."
    fi
    ;;

  switch)
    echo "📡 Checking connection..."
    if is_connected; then
      echo "✅ Trackpad is connected."
      echo "🗑️  Forgetting trackpad..."
      blueutil --unpair "$TRACKPAD_ID"
      echo "✅ Trackpad forgotten."
    else
      echo "⚠️  Trackpad not connected — skipping unpair."
    fi
    echo ""
    echo "💡 Put your trackpad in pairing mode (hold power button until LED blinks)"
    read -r "?Press Enter when ready..."
    echo "🔗 Sending pair request..."
    blueutil --pair "$TRACKPAD_ID" --connect "$TRACKPAD_ID"
    echo ""
    echo "📡 Verifying connection..."
    if is_connected; then
      echo "✅ Trackpad connected!"
    else
      echo "⚠️  Trackpad not detected yet — it may take a moment."
    fi
    ;;

  *)
    echo "Usage: trackpad-connect [forget|add|switch]"
    echo ""
    echo "  switch  - Forget then add again (default)"
    echo "  forget  - Remove trackpad so another Mac can claim it"
    echo "  add     - Pair trackpad with this Mac"
    exit 1
    ;;
esac
