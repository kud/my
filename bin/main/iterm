#!/usr/bin/env zsh

################################################################################
#                                                                              #
#   🖥  ITERM2 SUGAR                                                           #
#   ---------------                                                            #
#   Convenience wrappers around the iTerm2 it2api CLI.                        #
#                                                                              #
#   Usage:                                                                     #
#     iterm title <name>                    Set the tab title                 #
#     iterm pane [--right|--bottom] [cmd]   Split pane, run optional command  #
#     iterm tab  [cmd]                      Open new tab, run optional command #
#     iterm focus                           Bring iTerm2 window to front      #
#     iterm <it2api-cmd> [args]             Passthrough to it2api             #
#                                                                              #
################################################################################

case "$1" in

title)
  shift
  if command -v it2api &>/dev/null; then
    it2api set-name "$*"
  else
    echo -ne "\e]1;$*\a"
  fi
  ;;

pane)
  shift
  vertical_flag="--vertical"
  [[ "$1" == "--bottom" ]] && vertical_flag="" && shift
  [[ "$1" == "--right" ]] && shift
  session="${ITERM_SESSION_ID##*:}"
  new=$(it2api split-pane ${vertical_flag:+$vertical_flag} "$session")
  new_session="${${new##*id=}%% *}"
  [[ -n "$*" ]] && it2api send-text "$new_session" "$*
"
  ;;

tab)
  shift
  it2api create-tab ${1:+--command "$*"}
  ;;

focus)
  osascript -e 'tell application "iTerm2" to activate'
  ;;

--help|-h|help|"")
  local bold='\033[1m' cyan='\033[36m' dim='\033[2m' reset='\033[0m'
  echo -e "${bold}Usage:${reset} iterm <command> [options] [cmd]\n"
  echo -e "${bold}Commands:${reset}"
  echo -e "  ${cyan}title${reset} <name>                    Set the tab title"
  echo -e "  ${cyan}pane${reset} [--right|--bottom] [cmd]   Split right (default) or below, run command"
  echo -e "  ${cyan}tab${reset}  [cmd]                      Open new tab and run command"
  echo -e "  ${cyan}focus${reset}                           Bring iTerm2 to front"
  echo -e "\n${bold}it2api commands:${reset}"
  it2api --help 2>&1 | awk '
    /^    [a-z][a-z-]/ { if (cmd) print cmd "\t" desc; cmd=$1; $1=""; sub(/^ +/,""); desc=$0 }
    /^ {20,}/ && cmd && !desc { sub(/^ +/,""); desc=$0 }
    END { if (cmd) print cmd "\t" desc }
  ' | sort | awk -v cyan='\033[36m' -v dim='\033[2m' -v reset='\033[0m' -F'\t' '
    { printf "  %s%-30s%s %s%s%s\n", cyan, $1, reset, dim, $2, reset }
  '
  ;;

*)
  it2api "$@"
  ;;

esac
