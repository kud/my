#!/usr/bin/env zsh

# Fetch my open PRs and pick one to checkout via fzf
selected=$(
  gh pr list --author @me \
    --json number,title,headRefName,isDraft,reviewDecision \
    --jq '.[] | [
      ("#" + (.number | tostring)),
      (if .isDraft then "🚧" else
        if .reviewDecision == "APPROVED" then "✅" else
        if .reviewDecision == "CHANGES_REQUESTED" then "🔧" else
        "👀" end end end),
      .title,
      .headRefName
    ] | @tsv' \
  | fzf \
    --delimiter='\t' \
    --with-nth=1,2,3 \
    --preview='
      data=$(gh pr view {1} --json reviews,additions,deletions,headRefName 2>/dev/null)
      branch=$(echo "$data" | jq -r .headRefName)
      add=$(echo "$data" | jq -r .additions)
      del=$(echo "$data" | jq -r .deletions)

      printf "\033[1;36m⎇  %s\033[0m\n\n" "$branch"
      printf "\033[32m+%s\033[0m  \033[31m-%s\033[0m\n\n" "$add" "$del"
      printf "\033[1mReviewers\033[0m\n"

      echo "$data" | jq -r "
        [.reviews[] | {login: .author.login, state: .state}]
        | group_by(.login) | map(last)[] | .login + \" \" + .state
      " | while read -r login state; do
        case $state in
          APPROVED)           icon="✅"; color="\033[32m" ;;
          CHANGES_REQUESTED)  icon="🔧"; color="\033[31m" ;;
          COMMENTED)          icon="💬"; color="\033[33m" ;;
          DISMISSED)          icon="👻"; color="\033[90m" ;;
          *)                  icon="·";  color="\033[0m"  ;;
        esac
        printf "  %s \033[1m${color}%s\033[0m\n" "$icon" "$login"
      done
    ' \
    --preview-window=right:33%:wrap \
    --ansi \
    --height=40%
)

[[ -z "$selected" ]] && exit 0

branch=$(echo "$selected" | cut -f4)
git checkout "$branch"
